# Google Maps API Key
# Para obter sua chave API:
# 1. Acesse: https://console.cloud.google.com/
# 2. Crie um novo projeto ou selecione um existente
# 3. Ative a API "Maps JavaScript API"
# 4. Vá em "Credenciais" e crie uma chave API
# 5. Copie a chave e substitua no arquivo src/environments/environment.ts

GOOGLE_MAPS_API_KEY=SUA_CHAVE_API_GOOGLE_MAPS_AQUI
